PORT=3001
HOST=0.0.0.0

# Origen permitido por CORS para el frontend. Por defecto, el puerto de Vite.
CORS_ORIGIN=http://localhost:5173

# Cloudflare AI Gateway: único punto de acceso a modelos de IA.
# https://developers.cloudflare.com/ai-gateway/
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_GATEWAY_ID=
CLOUDFLARE_AI_GATEWAY_TOKEN=
# Timeout (ms) para cada llamada al gateway. Por defecto 15000 si se omite.
CLOUDFLARE_AI_GATEWAY_TIMEOUT_MS=15000

# PostgreSQL (Neon). Debe incluir sslmode=require (Neon lo exige).
# Si se omite, el backend usa el repositorio en memoria (útil para desarrollo local).
# https://neon.tech/docs/connect/connect-from-any-app
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
